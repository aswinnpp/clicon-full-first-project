<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clicon Store</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles/auth.css" />
  </head>
  <body class="auth-page">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-brand">Clicon</p>
        <h1 class="auth-heading">Forgot Password</h1>
        <p class="auth-subtext">Enter your email and we will send an OTP to reset your password.</p>

        <p class="auth-error"><%= typeof message !== 'undefined' ? message : '' %></p>

        <form action="/forgot" method="post">
          <div class="mb-3">
            <label for="sign-up-email" class="auth-label">Email address</label>
            <input type="email" class="auth-input" id="sign-up-email" placeholder="Enter your email" name="email" required />
          </div>

          <button type="submit" class="auth-btn">Send OTP</button>

          <div class="auth-link-row">
            <a href="/login" class="auth-link">Back to Sign In</a>
          </div>
        </form>
      </section>
    </main>
</body>
</html>