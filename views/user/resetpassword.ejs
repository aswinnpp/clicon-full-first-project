<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clicon Store</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles/auth.css" />
  </head>
  <body class="auth-page">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-brand">Clicon</p>
        <h1 class="auth-heading">Set New Password</h1>
        <p class="auth-subtext">Choose a strong new password for your account.</p>

        <form action="/reset" method="post">
          <p id="errorMessage" class="auth-error"></p>

          <div class="mb-3">
            <label for="sign-up-password" class="auth-label">New Password</label>
            <input
              name="newpassword"
              type="password"
              class="auth-input"
              id="sign-up-password"
              placeholder="Enter new password"
              required
            />
          </div>

          <div class="mb-3">
            <label for="sign-up-confirm-password" class="auth-label">Confirm Password</label>
            <input
              type="password"
              name="newconfirmpassword"
              class="auth-input"
              id="sign-up-confirm-password"
              placeholder="Confirm your password"
              required
            />
          </div>

          <button type="submit" class="auth-btn">Reset Password</button>
        </form>
      </section>
    </main>



<script>
 document.querySelector('form').addEventListener('submit', function (e) {
    const newPassword = document.getElementById('sign-up-password').value.trim();
    const confirmPassword = document.getElementById('sign-up-confirm-password').value.trim();
    const errorMessageElement = document.getElementById('errorMessage');

    errorMessageElement.innerHTML = '';

    // Regular expression for strong password
    const strongPasswordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;

    if (newPassword === '') {
        e.preventDefault();
        errorMessageElement.innerHTML = 'New password cannot be empty.';
    } else if (!strongPasswordRegex.test(newPassword)) {
        e.preventDefault();
        errorMessageElement.innerHTML = 'Password must be at least 8 characters long, contain an uppercase letter, a lowercase letter, a number, and a special character.';
    } else if (confirmPassword === '') {
        e.preventDefault();
        errorMessageElement.innerHTML = 'Please confirm your password.';
    } else if (newPassword !== confirmPassword) {
        e.preventDefault();
        errorMessageElement.innerHTML = 'Passwords do not match.';
    }
});

</script>


</body>
</html>
