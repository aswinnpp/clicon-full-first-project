<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clicon Store</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles/auth.css" />
  </head>
  <body class="auth-page">
    <main class="auth-shell">
      <section class="auth-card">
        <p class="auth-brand">Clicon</p>
        <h1 class="auth-heading">OTP Verification</h1>
        <p class="auth-subtext">Enter the OTP sent to your email to continue.</p>

        <form action="/otp" method="POST" id="otpForm">
          <p class="auth-error"><%= typeof OTP !== 'undefined' ? OTP : '' %></p>

          <div class="mb-3">
            <label for="otp" class="auth-label">Enter OTP</label>
            <input
              type="text"
              class="auth-input"
              id="otp"
              name="otp"
              placeholder="Enter 6-digit OTP"
              maxlength="10"
              required
            />
          </div>

          <button type="submit" class="auth-btn">Verify OTP</button>
          <div id="timer" class="otp-timer">60</div>
        </form>

        <form action="/resend" method="post">
          <button
            type="submit"
            class="otp-resend-btn"
            id="resendOtpBtn"
            onsubmit="toggleButtonState()"
            disabled
          >
            Resend OTP
          </button>
        </form>
      </section>
    </main>

<script>
  const button = document.getElementById("resendOtpBtn");
  const timerDisplay = document.getElementById("timer");

  function toggleButtonState() {
    button.disabled = true;
    setTimeout(function () {
      button.disabled = false;
    }, 62000);
  }

  setTimeout(function () {
    button.disabled = false;
  }, 62000);

  function startTimer() {
    let timeLeft = 60;

    const interval = setInterval(function () {
      timerDisplay.textContent = timeLeft;
      timeLeft--;

      if (timeLeft < 0) {
        clearInterval(interval);
        timerDisplay.textContent = "";
      }
    }, 1000);
  }

  window.onload = function () {
    startTimer();
  };
</script>
</body>
</html>
